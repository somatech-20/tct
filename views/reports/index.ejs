<div class="max-w-full px-4 md:px-6">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 md:gap-6 mb-6 md:mb-8">

        <!-- Total -->
        <div class="rounded-xl bg-gradient-to-br from-slate-700 to-slate-900 shadow-lg p-6 text-white">
            <p class="text-sm text-slate-300">Total Patients</p>
            <p class="mt-2 text-3xl font-bold">
                <%= stats.total %>
            </p>
        </div>

        <!-- Active -->
        <div class="rounded-xl bg-gradient-to-br from-emerald-500 to-emerald-700 shadow-lg p-6 text-white">
            <p class="text-sm text-emerald-100">Active</p>
            <p class="mt-2 text-3xl font-bold">
                <%= stats.active %>
            </p>
        </div>

        <!-- Recovered -->
        <div class="rounded-xl bg-gradient-to-br from-sky-500 to-cyan-600 shadow-lg p-6 text-white">
            <p class="text-sm text-sky-100">Recovered</p>
            <p class="mt-2 text-3xl font-bold">
                <%= stats.recovered %>
            </p>
        </div>

        <!-- Defaulted -->
        <div class="rounded-xl bg-gradient-to-br from-amber-500 to-orange-600 shadow-lg p-6 text-white">
            <p class="text-sm text-amber-100">Defaulted</p>
            <p class="mt-2 text-3xl font-bold">
                <%= stats.defaulted %>
            </p>
        </div>

    </div>

    <!-- Filters Section -->
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-lg p-4 md:p-6 mb-6">
        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-4 gap-3">
            <h3 class="text-lg font-semibold text-gray-800 dark:text-white">🔍 Filters & Export</h3>
            <div class="flex flex-wrap gap-2 w-full sm:w-auto">
                <button id="exportBtn"
                    class="bg-indigo-600 hover:bg-indigo-700 text-white px-4 py-2 rounded-lg flex items-center justify-center w-full sm:w-auto transition duration-200">
                    <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                    </svg>
                    Export Report
                </button>
            </div>
        </div>

        <!-- Filters & Export -->
        <div
            class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-5 mb-6">
            <!-- Top Row -->
            <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4 mb-4">
                <!-- Search -->
                <div class="w-full lg:max-w-md">
                    <div class="relative">
                        <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400" fill="none"
                            stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                        </svg>
                        <input type="text" form="filterForm" name="search" value="<%= filters.search || '' %>"
                            placeholder="Search patient, phone, ID..."
                            class="w-full pl-10 pr-4 py-2.5 text-sm bg-gray-50 dark:bg-gray-700 border border-gray-300 dark:border-gray-600 rounded-xl focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent dark:text-white transition">
                    </div>
                </div>
                <!-- Export
                <button id="exportBtn" type="button"
                    class="inline-flex items-center justify-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white px-5 py-2.5 rounded-xl text-sm font-medium transition shadow-sm">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                    </svg>
                    Export Report
                </button> -->
            </div>
            <!-- Filters -->
            <form id="filterForm" method="GET" action="/reports" class="flex flex-wrap items-center gap-3">
                <!-- Status -->
                <select name="status"
                    class="min-w-[150px] px-3 py-2.5 text-sm bg-gray-50 dark:bg-gray-700 border border-gray-300 dark:border-gray-600 rounded-xl focus:outline-none focus:ring-2 focus:ring-indigo-500 dark:text-white">
                    <option value="">All Status</option>
                    <option value="Active" <%=filters.status==='Active' ? 'selected' : '' %>>
                        Active
                    </option>
                    <option value="Recovered" <%=filters.status==='Recovered' ? 'selected' : '' %>>
                        Recovered
                    </option>
                    <option value="Defaulted" <%=filters.status==='Defaulted' ? 'selected' : '' %>>
                        Defaulted
                    </option>
                </select>

                <!-- District -->
                <select name="district"
                    class="min-w-[170px] px-3 py-2.5 text-sm bg-gray-50 dark:bg-gray-700 border border-gray-300 dark:border-gray-600 rounded-xl focus:outline-none focus:ring-2 focus:ring-indigo-500 dark:text-white">
                    <option value="">All Districts</option>
                    <% districts.forEach(d=> { %>
                        <option value="<%= d %>" <%=filters.district===d ? 'selected' : '' %>>
                            <%= d %>
                        </option>
                        <% }) %>
                </select>

                <!-- Doctor -->
                <select name="doctor"
                    class="min-w-[170px] px-3 py-2.5 text-sm bg-gray-50 dark:bg-gray-700 border border-gray-300 dark:border-gray-600 rounded-xl focus:outline-none focus:ring-2 focus:ring-indigo-500 dark:text-white">

                    <option value="">All Doctors</option>

                    <% doctors.forEach(d=> { %>

                        <option value="<%= d._id %>" <%=filters.doctor===d._id.toString() ? 'selected' : '' %>>

                            <%= d.fullName || d.username %>
                        </option>
                        <% }) %>
                </select>
                <!-- Returnee -->
                <select name="returnee"
                    class="min-w-[150px] px-3 py-2.5 text-sm bg-gray-50 dark:bg-gray-700 border border-gray-300 dark:border-gray-600 rounded-xl focus:outline-none focus:ring-2 focus:ring-indigo-500 dark:text-white">
                    <option value="">All Patients</option>
                    <option value="true" <%=filters.returnee==='true' ? 'selected' : '' %>>
                        Returnee
                    </option>
                    <option value="false" <%=filters.returnee==='false' ? 'selected' : '' %>>
                        Non-Returnee
                    </option>
                </select>
                <!-- Spacer -->
                <div class="flex-1"></div>
                <!-- Reset -->
                <a href="/reports"
                    class="px-4 py-2.5 rounded-xl border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-600 transition text-sm font-medium">
                    Reset
                </a>
                <!-- Apply -->
                <button type="submit"
                    class="px-5 py-2.5 rounded-xl bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-medium transition shadow-sm">
                    Apply Filters
                </button>
            </form>
        </div>
    </div>

    <!-- Patient Table -->
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-lg overflow-hidden">
        <div
            class="px-4 md:px-6 py-4 border-b border-gray-200 dark:border-gray-700 flex justify-between items-center flex-wrap gap-2">
            <h3 class="text-lg font-semibold text-gray-800 dark:text-white">Patients (<%= patients.length %>)</h3>
            <span class="text-sm text-gray-500 dark:text-gray-400">
                Showing <%= patients.length %> of <%= patients.length %> total
            </span>
        </div>
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
                <thead class="bg-gray-50 dark:bg-gray-700">
                    <tr>
                        <th
                            class="px-3 md:px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase">
                            Patient ID</th>
                        <th
                            class="px-3 md:px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase">
                            Name</th>
                        <th
                            class="px-3 md:px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase hidden sm:table-cell">
                            District</th>
                        <th
                            class="px-3 md:px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase hidden lg:table-cell">
                            Doctor</th>
                        <th
                            class="px-3 md:px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase">
                            Status</th>
                        <th
                            class="px-3 md:px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase hidden md:table-cell">
                            Returnee</th>
                        <th
                            class="px-3 md:px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase">
                            Actions</th>
                    </tr>
                </thead>
                <tbody class="bg-white dark:bg-gray-800 divide-y divide-gray-200 dark:divide-gray-700">
                    <% patients.forEach(patient=> { %>
                        <tr class="hover:bg-gray-50 dark:hover:bg-gray-700 transition duration-150">
                            <td class="px-3 md:px-6 py-4 text-xs md:text-sm font-mono text-gray-600 dark:text-gray-300">
                                <%= patient.patientId || 'N/A' %>
                            </td>
                            <td class="px-3 md:px-6 py-4">
                                <a href="/patients/<%= patient._id %>"
                                    class="text-indigo-600 dark:text-indigo-400 hover:text-indigo-900 dark:hover:text-indigo-300 text-sm md:text-base">
                                    <%= patient.fullName %>
                                </a>
                            </td>
                            <td class="px-3 md:px-6 py-4 text-sm hidden sm:table-cell">
                                <%= patient.district || 'N/A' %>
                            </td>
                            <td class="px-3 md:px-6 py-4 text-sm hidden lg:table-cell">
                                <%= patient.assignedDoctor ? (patient.assignedDoctor.fullName ||
                                    patient.assignedDoctor.username) : 'Unassigned' %>
                            </td>
                            <td class="px-3 md:px-6 py-4">
                                <span class="px-2 py-1 inline-flex text-xs leading-5 font-semibold rounded-full 
                            <% if (patient.status === 'Active') { %>bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200<% } 
                            else if (patient.status === 'Recovered') { %>bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-200<% } 
                            else { %>bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-200<% } %>">
                                    <%= patient.status %>
                                </span>
                            </td>
                            <td class="px-3 md:px-6 py-4 text-sm hidden md:table-cell">
                                <%= patient.isReturnee ? '✅ Yes' : '❌ No' %>
                            </td>
                            <td class="px-3 md:px-6 py-4">
                                <a href="/patients/<%= patient._id %>"
                                    class="text-indigo-600 dark:text-indigo-400 hover:text-indigo-900 dark:hover:text-indigo-300 text-sm">View</a>
                            </td>
                        </tr>
                        <% }); %>
                            <% if (patients.length===0) { %>
                                <tr>
                                    <td colspan="7" class="px-6 py-8 text-center text-gray-500 dark:text-gray-400">
                                        <svg class="w-12 h-12 mx-auto text-gray-400 dark:text-gray-600 mb-3" fill="none"
                                            stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                d="M9 17V7m0 10a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2h2a2 2 0 012 2m0 10a2 2 0 002 2h2a2 2 0 002-2M9 7a2 2 0 012-2h2a2 2 0 012 2m0 10V7m0 10a2 2 0 002 2h2a2 2 0 002-2V7a2 2 0 00-2-2h-2a2 2 0 00-2 2" />
                                        </svg>
                                        <p>No patients found matching your filters.</p>
                                    </td>
                                </tr>
                                <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Export Modal -->
<div id="exportModal" class="fixed inset-0 bg-gray-600 bg-opacity-50 overflow-y-auto h-full w-full z-50 hidden">
    <div class="relative top-10 mx-auto p-5 border w-11/12 max-w-2xl shadow-lg rounded-md bg-white dark:bg-gray-800">
        <div class="flex justify-between items-center border-b pb-3 mb-4">
            <h3 class="text-lg font-bold">Export Report</h3>
            <button id="closeExportModal" class="text-gray-400 hover:text-gray-600">&times;</button>
        </div>

        <form id="exportForm" method="POST" action="/reports/export" target="_blank" class="no-loader">
            <!-- Format Selection -->
            <div class="mb-4">
                <label class="block text-gray-700 dark:text-gray-300 text-sm font-bold mb-2">
                    <h4 class="text-sm font-semibold uppercase tracking-wide text-gray-500 mb-3">Select Format</h4>
                </label>
                <div class="grid grid-cols-3 gap-2">
                    <button type="button" data-format="pdf"
                        class="format-btn px-4 py-2 border rounded hover:bg-indigo-50 dark:hover:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-indigo-500">
                        <svg class="w-6 h-6 mx-auto text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
                        </svg>
                        <span class="text-sm mt-1">PDF</span>
                    </button>
                    <button type="button" data-format="excel"
                        class="format-btn px-4 py-2 border rounded hover:bg-indigo-50 dark:hover:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-indigo-500">
                        <svg class="w-6 h-6 mx-auto text-green-500" fill="none" stroke="currentColor"
                            viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M9 17V7m0 10a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2h2a2 2 0 012 2m0 10a2 2 0 002 2h2a2 2 0 002-2M9 7a2 2 0 012-2h2a2 2 0 012 2m0 10V7m0 10a2 2 0 002 2h2a2 2 0 002-2V7a2 2 0 00-2-2h-2a2 2 0 00-2 2" />
                        </svg>
                        <span class="text-sm mt-1">Excel</span>
                    </button>
                    <button type="button" data-format="csv"
                        class="format-btn px-4 py-2 border rounded hover:bg-indigo-50 dark:hover:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-indigo-500">
                        <svg class="w-6 h-6 mx-auto text-blue-500" fill="none" stroke="currentColor"
                            viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M4 6h16M4 10h16M4 14h16M4 18h16" />
                        </svg>
                        <span class="text-sm mt-1">CSV</span>
                    </button>
                </div>
                <input type="hidden" name="format" id="selectedFormat"
                    class="bg-indigo-50 border-indigo-600 ring-2 ring-indigo-500" value="pdf">
            </div>

            <!-- Date Field Toggle -->
            <div class="mb-6">
                <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-3">
                    <h4 class="text-sm font-semibold uppercase tracking-wide text-gray-500 mb-3">Date Range Based On
                    </h4>
                </label>

                <div class="grid grid-cols-2 gap-3">

                    <label
                        class="cursor-pointer rounded-xl border border-gray-300 dark:border-gray-600 p-3 flex items-center justify-center transition-all hover:border-indigo-500 has-[:checked]:bg-indigo-600 has-[:checked]:text-white has-[:checked]:border-indigo-600">

                        <input type="radio" name="dateField" value="treatmentStartDate" checked class="hidden">

                        <span class="font-medium">
                            Treatment Start Date
                        </span>

                    </label>

                    <label
                        class="cursor-pointer rounded-xl border border-gray-300 dark:border-gray-600 p-3 flex items-center justify-center transition-all hover:border-indigo-500 has-[:checked]:bg-indigo-600 has-[:checked]:text-white has-[:checked]:border-indigo-600">

                        <input type="radio" name="dateField" value="createdAt" class="hidden">

                        <span class="font-medium">
                            Created Date
                        </span>

                    </label>

                </div>
            </div>

            <!-- Quick Select: Years & Months -->
            <div class=" rounded-2xl border border-gray-700 bg-gradient-to-b from-gray-800 to-gray-900 p-5 shadow-inner space-y-5 "
                <label class="block text-gray-700 dark:text-gray-300 text-sm font-bold mb-2">
                <h4 class="text-sm font-semibold uppercase tracking-wide text-gray-500 mb-3">Quick Select</h4></label>
                <div id="yearAccordion"
                    class=" max-h-64 overflow-y-auto rounded-xl border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-900 p-3 space-y-3 ">
                    <!-- Years will be populated by JavaScript -->
                </div>
                <p class="text-xs text-gray-500 mt-1">Double-click a year to select entire year, click a year to expand, click a month to select.</p>
            </div>

            <!-- Custom Range -->
            <div class="mb-4 grid grid-cols-2 gap-4">
                <div>
                    <label class="block text-gray-700 dark:text-gray-300 text-sm font-bold mb-1">Start Date</label>
                    <input type="date" name="startDate" id="customStartDate"
                        class=" w-full rounded-xl border border-gray-300 dark:border-gray-600 bg-gray-50 dark:bg-gray-700 px-4 py-3 text-sm focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500 transition ">
                </div>
                <div>
                    <label class="block text-gray-700 dark:text-gray-300 text-sm font-bold mb-1">End Date</label>
                    <input type="date" name="endDate" id="customEndDate"
                        class=" w-full rounded-xl border border-gray-300 dark:border-gray-600 bg-gray-50 dark:bg-gray-700 px-4 py-3 text-sm focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500 transition ">
                </div>
            </div>

            <!-- Hidden fields to pass current filters -->
            <input type="hidden" name="doctor" value="<%= filters.doctor || '' %>">
            <input type="hidden" name="status" value="<%= filters.status || '' %>">
            <input type="hidden" name="district" value="<%= filters.district || '' %>">
            <input type="hidden" name="returnee" value="<%= filters.returnee || '' %>">
            <input type="hidden" name="search" value="<%= filters.search || '' %>">

            <div class="mt-4 flex justify-end space-x-2">
                <button type="button" id="cancelExport"
                    class="bg-gray-500 hover:bg-gray-600 text-gray-800 rounded-xl px-5 py-2.5">Cancel</button>
                <button type="submit" id="confirmExport"
                    class="bg-indigo-600 hover:bg-indigo-700 text-white rounded-xl px-6 py-2.5 shadow-lg hover:shadow-xl transition"
                    disabled>Export</button>
            </div>
        </form>
    </div>
</div>

<script nonce="<%= nonce %>">
    document.addEventListener("DOMContentLoaded", () => {

        // ==========================
        // Elements
        // ==========================
        const exportBtn = document.getElementById("exportBtn");
        const exportModal = document.getElementById("exportModal");
        const exportForm = document.getElementById("exportForm");

        const closeBtn = document.getElementById("closeExportModal");
        const cancelBtn = document.getElementById("cancelExport");

        const confirmBtn = document.getElementById("confirmExport");
        const formatInput = document.getElementById("selectedFormat");

        const startInput = document.getElementById("customStartDate");
        const endInput = document.getElementById("customEndDate");

        const accordion = document.getElementById("yearAccordion");

        let selectedMonthBtn = null;

        // ==========================
        // Build Year Accordion Once
        // ==========================
        function buildYearAccordion() {

            const currentYear = new Date().getFullYear();
            const startYear = 2020;

            const months = [
                "Jan", "Feb", "Mar", "Apr", "May", "Jun",
                "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"
            ];

            accordion.innerHTML = "";

            for (let year = currentYear; year >= startYear; year--) {

                const wrapper = document.createElement("div");
                wrapper.className = "mb-2";

                wrapper.innerHTML = `
                <div class="year-toggle cursor-pointer rounded-xl border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 hover:border-indigo-500 hover:shadow transition flex justify-between items-center px-4 py-3"
                    data-year="${year}">
                    <div class="flex items-center gap-3">
                        <div
                            class="w-10 h-10 rounded-lg bg-indigo-100 dark:bg-indigo-900 flex items-center justify-center">
                                📅
                        </div>
                        <span class="font-semibold text-gray-700 dark:text-gray-200">
                            ${year}
                        </span>
                    </div>
                    <span class="arrow text-gray-400">
                        ▼
                    </span>
                </div>

                <div class=" month-grid hidden grid grid-cols-4 gap-2 mt-3 mb-4 px-1 ">

                    ${months.map((m, index) => `
                        <button
                            type="button"
                            class=" month-btn rounded-lg border border-gray-300 dark:border-gray-600 py-2 text-sm font-medium transition hover:border-indigo-500 hover:bg-indigo-50 dark:hover:bg-indigo-900 "
                            data-year="${year}"
                            data-month="${index + 1}">
                            ${m}
                        </button>
                    `).join("")}

                </div>
            `;

                accordion.appendChild(wrapper);
            }

            bindAccordionEvents();
        }

        // ==========================
        // Accordion Events
        // ==========================
        function bindAccordionEvents() {

            // Expand / Collapse
            accordion.querySelectorAll(".year-toggle").forEach(toggle => {

                toggle.addEventListener("click", function () {

                    const grid = this.nextElementSibling;

                    grid.classList.toggle("hidden");

                    this.lastElementChild.textContent =
                        grid.classList.contains("hidden") ? "▼" : "▲";
                });

                // Double click = whole year
                toggle.addEventListener("dblclick", function () {
                    clearSelections();
                    const year = parseInt(this.dataset.year);

                    startInput.value = `${year}-01-01`;
                    endInput.value = `${year}-12-31`;

                    this.classList.add(
                        "border-indigo-600",
                        "ring-2",
                        "ring-indigo-300"
                    );

                });

            });

            // Month click
            accordion.querySelectorAll(".month-btn").forEach(btn => {
                btn.addEventListener("click", function () {

                    // Clicking the currently selected month -> deselect it
                    if (selectedMonthBtn === this) {

                        this.classList.remove(
                            "bg-indigo-600",
                            "text-white",
                            "border-indigo-600"
                        );

                        selectedMonthBtn = null;

                        startInput.value = "";
                        endInput.value = "";

                        return;
                    }

                    // Deselect previously selected month
                    if (selectedMonthBtn) {
                        selectedMonthBtn.classList.remove(
                            "bg-indigo-600",
                            "text-white",
                            "border-indigo-600"
                        );
                    }

                    // Select the clicked month
                    selectedMonthBtn = this;

                    this.classList.add(
                        "bg-indigo-600",
                        "text-white",
                        "border-indigo-600"
                    );

                    const year = Number(this.dataset.year);
                    const month = Number(this.dataset.month);

                    const first = new Date(year, month - 1, 1);
                    const last = new Date(year, month, 0);

                    startInput.value = formatDate(first);
                    endInput.value = formatDate(last);
                });

            });
        }

        // ==========================
        // Helpers
        // ==========================
        function formatDate(date) {
            const y = date.getFullYear();
            const m = String(date.getMonth() + 1).padStart(2, "0");
            const d = String(date.getDate()).padStart(2, "0");

            return `${y}-${m}-${d}`;

        }

        function clearSelections() {
            accordion.querySelectorAll(".year-toggle")
                .forEach(el => {
                    el.classList.remove(
                        "border-indigo-600",
                        "ring-2",
                        "ring-indigo-300"
                    );
                });

            accordion.querySelectorAll(".month-btn")
                .forEach(el => {
                    el.classList.remove(
                        "bg-indigo-200",
                        "dark:bg-indigo-800"
                    );
                });

            selectedMonthBtn = null;

            startInput.value = "";
            endInput.value = "";
        }

        // ==========================
        // Reset Modal
        // ==========================
        function resetModal() {
            exportForm.reset();
            clearSelections();
            document.querySelectorAll(".format-btn")
                .forEach(btn => {
                    btn.classList.remove(
                        "bg-indigo-600",
                        "text-white",
                        "border-indigo-600"
                    );
                });

            // Default format
            formatInput.value = "pdf";
            const defaultBtn = document.querySelector(
                '.format-btn[data-format="pdf"]'
            );
            defaultBtn.classList.add(
                "bg-indigo-100",
                "border-indigo-500"
            );
            confirmBtn.disabled = false;
            confirmBtn.textContent = "Export";
        }

        // ==========================
        // Open / Close
        // ==========================
        function openModal() {
            resetModal();
            exportModal.classList.remove("hidden");
        }

        function closeModal() {
            resetModal();
            exportModal.classList.add("hidden");
        }

        exportBtn.addEventListener("click", openModal);
        closeBtn.addEventListener("click", closeModal);
        cancelBtn.addEventListener("click", closeModal);
        window.addEventListener("click", (e) => {

            if (e.target === exportModal) {
                closeModal();
            }
        });

        // ==========================
        // Format Selection
        // ==========================
        document.querySelectorAll(".format-btn")
            .forEach(btn => {
                btn.addEventListener("click", function () {
                    document.querySelectorAll(".format-btn")
                        .forEach(b => b.classList.remove(
                            "bg-indigo-100",
                            "border-indigo-500"
                        ));
                    this.classList.add(
                        "bg-indigo-100",
                        "border-indigo-500"
                    );
                    formatInput.value = this.dataset.format;
                });
            });

        // ==========================
        // Form Submit
        // ==========================
        exportForm.addEventListener("submit", (e) => {
            if (!startInput.value || !endInput.value) {
                e.preventDefault();
                alert("Please select a date range.");
                return;
            }
            confirmBtn.disabled = true;
            confirmBtn.textContent = "Exporting...";

            // Let the browser submit normally.
            // No timeout needed.
            closeModal();
        });

        // ==========================
        // Initialize
        // ==========================
        buildYearAccordion();

    });
</script>