<div class="bg-white rounded-lg shadow overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-200 flex justify-between items-center">
        <h2 class="text-xl font-semibold"><%= t('manage_users') %></h2>
        <a href="/users/new" class="bg-indigo-600 hover:bg-indigo-700 text-white px-4 py-2 rounded text-sm flex items-center">
            <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/></svg>
            <%= t('add_user') %>
        </a>
    </div>
    <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
                <tr>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t('username') %></th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t('role') %></th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t('actions') %></th>
                </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
                <% users.forEach(user => { %>
                <tr>
                    <td class="px-6 py-4 whitespace-nowrap"><%= user.username %></td>
                    <td class="px-6 py-4 whitespace-nowrap">
                        <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full 
                        <% if (user.role === 'admin') { %>bg-purple-100 text-purple-800<% } 
                        else if (user.role === 'doctor') { %>bg-green-100 text-green-800<% } 
                        else { %>bg-gray-100 text-gray-800<% } %>">
                            <%= user.role %>
                        </span>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap">
                        <a href="/users/<%= user._id %>/edit" class="text-yellow-600 hover:text-yellow-900 mr-3"><%= t('edit') %></a>
                        <form method="POST" action="/users/<%= user._id %>?_method=DELETE" style="display:inline;" onsubmit="return confirm('Delete this user?')">
                            <button type="submit" class="text-red-600 hover:text-red-900"><%= t('delete') %></button>
                        </form>
                    </td>
                </tr>
                <% }); %>
            </tbody>
        </table>
    </div>
</div>