<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TB Case Tracer</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Heroicons -->
    <script src="https://unpkg.com/@heroicons/react/24/outline/index.js"></script>
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
    <style>
        /* Custom loading spinner */
        .loader {
            border-top-color: #3490dc;
            animation: spin 1s linear infinite;
        }

        @keyframes spin {
            0% {
                transform: rotate(0deg);
            }

            100% {
                transform: rotate(360deg);
            }
        }

        .sidebar {
            transition: transform 0.3s ease-in-out;
            transform: translateX(-100%);
            /* hidden by default on mobile */
            z-index: 40;
        }

        .sidebar.open {
            transform: translateX(0);
        }

        .sidebar-backdrop {
            position: fixed;
            inset: 0;
            background-color: rgba(0, 0, 0, 0.5);
            z-index: 30;
            display: none;
        }

        .sidebar-backdrop.active {
            display: block;
        }

        @media (min-width: 766px) {
            .sidebar {
                transform: translateX(0) !important;
                /* always visible on desktop */
            }

            .menu-toggle,
            .sidebar-close,
            .sidebar-backdrop {
                display: none !important;
            }
        }

        .sidebar {
            scrollbar-width: thin;
            /* Firefox */
            -ms-overflow-style: none;
            /* IE/Edge */
        }

        .sidebar::-webkit-scrollbar {
            display: none;
            /* Chrome/Safari */
        }

        /* ===== DARK MODE OVERRIDES (MODERN & SMOOTH) ===== */
        .dark {
            background-color: #0f172a;
            /* Slate-900 */
            color: #e2e8f0;
            /* Slate-200 */
        }

        /* Backgrounds */
        .dark .bg-white {
            background-color: #1e293b;
        }

        /* Slate-800 */
        .dark .bg-gray-100 {
            background-color: #0f172a;
        }

        .dark .bg-gray-50 {
            background-color: #1e293b;
        }

        .dark .bg-gray-200 {
            background-color: #334155;
        }

        .dark .bg-indigo-100 {
            background-color: #1e1b4b;
            color: #c7d2fe;
        }

        /* Text colors */
        .dark .text-gray-800 {
            color: #f1f5f9;
        }

        .dark .text-gray-700 {
            color: #cbd5e1;
        }

        .dark .text-gray-600 {
            color: #94a3b8;
        }

        .dark .text-gray-500 {
            color: #64748b;
        }

        .dark .text-indigo-600 {
            color: #818cf8;
        }

        .dark .text-indigo-800 {
            color: #a5b4fc;
        }

        /* Borders */
        .dark .border-gray-200 {
            border-color: #334155;
        }

        .dark .border-gray-300 {
            border-color: #475569;
        }

        .dark .divide-gray-200> :not([hidden])~ :not([hidden]) {
            border-color: #334155;
        }

        /* Input fields (text, password, textarea, select) */
        .dark input,
        .dark textarea,
        .dark select,
        .dark input[type="text"],
        .dark input[type="password"],
        .dark input[type="email"],
        .dark input[type="number"],
        .dark input[type="date"] {
            background-color: #0f172a;
            border-color: #475569;
            color: #f1f5f9;
        }

        .dark input:focus,
        .dark textarea:focus,
        .dark select:focus {
            border-color: #6366f1;
            outline: none;
            ring: 2px solid #6366f1;
            background-color: #1e293b;
        }

        .dark input::placeholder,
        .dark textarea::placeholder {
            color: #64748b;
        }

        /* Disabled inputs (profile page) */
        .dark input:disabled {
            background-color: #334155;
            color: #94a3b8;
        }

        /* Cards, shadows, hover */
        .dark .shadow {
            box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.5);
        }

        .dark .shadow-lg {
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.5);
        }

        .dark .hover\:bg-gray-100:hover {
            background-color: #334155;
        }

        .dark .hover\:bg-gray-200:hover {
            background-color: #475569;
        }

        .dark .hover\:bg-indigo-700:hover {
            background-color: #4338ca;
        }

        /* Buttons */
        .dark .bg-indigo-600 {
            background-color: #4f46e5;
        }

        .dark .bg-indigo-600:hover {
            background-color: #6366f1;
        }

        .dark .bg-indigo-700 {
            background-color: #4338ca;
        }

        .dark .bg-red-100 {
            background-color: #7f1a1a;
            color: #fecaca;
        }

        .dark .bg-green-100 {
            background-color: #064e3b;
            color: #bbf7d0;
        }

        .dark .bg-blue-100 {
            background-color: #1e3a8a;
            color: #bfdbfe;
        }

        .dark .bg-yellow-100 {
            background-color: #713f12;
            color: #fef08a;
        }

        /* Badge backgrounds */
        .dark .bg-green-100 {
            background-color: #14532d;
            color: #bbf7d0;
        }

        .dark .bg-red-100 {
            background-color: #7f1a1a;
            color: #fecaca;
        }

        .dark .bg-blue-100 {
            background-color: #1e3a8a;
            color: #bfdbfe;
        }

        .dark .bg-purple-100 {
            background-color: #4c1d95;
            color: #ddd6fe;
        }

        .dark .bg-gray-100 {
            background-color: #334155;
            color: #e2e8f0;
        }

        /* Sidebar (blends smoothly) */
        .dark .bg-indigo-800 {
            background: linear-gradient(135deg, #1e1b4b 0%, #111827 100%);
        }

        .dark .bg-indigo-700 {
            background-color: #2e2a5e;
        }

        .dark .hover\:bg-indigo-700:hover {
            background-color: #4338ca;
        }

        /* Tables */
        .dark table tbody tr {
            border-bottom-color: #334155;
        }

        .dark .bg-white .overflow-x-auto table thead {
            background-color: #1e293b;
        }

        .dark .bg-white .overflow-x-auto table tbody tr:hover {
            background-color: #334155;
        }

        /* Modal styles for dark mode */
        .dark #settingsModal .bg-white {
            background-color: #1e293b;
        }

        .dark #settingsModal .text-gray-400 {
            color: #94a3b8;
        }

        .dark #settingsModal .border {
            border-color: #475569;
        }

        .hidden-field {
            display: none;
        }

        /* .visible-field {
            display: block;
        } */
        .field-error {
            border-color: #ef4444 !important;
            background-color: #fef2f2 !important;
        }

        .field-error:focus {
            border-color: #ef4444 !important;
            ring: 2px solid #ef4444 !important;
        }

        #yearAccordion::-webkit-scrollbar {
            width: 8px;
        }

        #yearAccordion::-webkit-scrollbar-track {
            background: transparent;
        }

        #yearAccordion::-webkit-scrollbar-thumb {
            background: #6366f1;
            border-radius: 9999px;
        }

        #yearAccordion::-webkit-scrollbar-thumb:hover {
            background: #4f46e5;
        }
    </style>
</head>

<body class="bg-gray-100">
    <div class="flex h-screen relative">
        <!-- Backdrop -->
        <div id="sidebarBackdrop" class="sidebar-backdrop"></div>

        <!-- <pre>
            <%= JSON.stringify(user, null, 2) %>
        </pre> -->
        <!-- Sidebar with responsive class -->
        <!-- <aside id="sidebar" class="sidebar fixed md:relative z-30 w-64 bg-indigo-800 text-white h-full overflow-y-auto"> -->
        <aside id="sidebar" class="sidebar fixed md:relative z-30 w-64 bg-indigo-800 text-white h-full overflow-y-auto">
            <%- include('../partials/sidebar') %>
        </aside>
        <div class="flex-1 flex flex-col overflow-hidden">
            <%- include('../partials/header') %>
                <!-- <main class="flex-1 overflow-x-hidden overflow-y-auto bg-gray-100 p-6"> -->
                <main class="flex-1 overflow-x-hidden overflow-y-auto bg-gray-100 p-4 md:p-6">
                    <!-- Flash messages -->
                    <% if (locals.error) { %>
                        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative mb-4"
                            role="alert">
                            <strong class="font-bold">Error!</strong>
                            <span class="block sm:inline">
                                <%= error %>
                            </span>
                            <span class="absolute top-0 bottom-0 right-0 px-4 py-3">
                                <svg class="fill-current h-6 w-6 text-red-500" role="button"
                                    xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20">
                                    <title>Close</title>
                                    <path
                                        d="M14.348 5.652a1 1 0 0 0-1.414 0L10 8.586 7.066 5.652a1 1 0 1 0-1.414 1.414L8.586 10l-2.934 2.934a1 1 0 1 0 1.414 1.414L10 11.414l2.934 2.934a1 1 0 0 0 1.414-1.414L11.414 10l2.934-2.934a1 1 0 0 0 0-1.414z" />
                                </svg>
                            </span>
                        </div>
                        <% } %>
                            <% if (locals.success) { %>
                                <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded relative mb-4"
                                    role="alert">
                                    <strong class="font-bold">Success!</strong>
                                    <span class="block sm:inline">
                                        <%= success %>
                                    </span>
                                    <span class="absolute top-0 bottom-0 right-0 px-4 py-3">
                                        <svg class="fill-current h-6 w-6 text-green-500" role="button"
                                            xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20">
                                            <title>Close</title>
                                            <path
                                                d="M14.348 5.652a1 1 0 0 0-1.414 0L10 8.586 7.066 5.652a1 1 0 1 0-1.414 1.414L8.586 10l-2.934 2.934a1 1 0 1 0 1.414 1.414L10 11.414l2.934 2.934a1 1 0 0 0 1.414-1.414L11.414 10l2.934-2.934a1 1 0 0 0 0-1.414z" />
                                        </svg>
                                    </span>
                                </div>
                                <% } %>
                                    <%- body %>
                </main>
        </div>
    </div>
    <!-- Loading overlay (hidden by default) -->
    <div id="loadingOverlay"
        class="fixed inset-0 bg-gray-600 bg-opacity-50 flex items-center justify-center z-50 hidden">
        <div class="bg-white p-5 rounded-lg shadow-lg flex items-center space-x-3">
            <div class="loader ease-linear rounded-full border-4 border-t-4 border-gray-200 h-12 w-12"></div>
            <span class="text-gray-700">Processing...</span>
        </div>
    </div>

    <!-- Settings Modal -->
    <div id="settingsModal"
        class="fixed inset-0 bg-gray-900 bg-opacity-50 dark:bg-opacity-70 overflow-y-auto h-full w-full z-50 hidden">
        <div
            class="relative top-20 mx-auto p-5 border w-96 shadow-xl rounded-lg bg-white dark:bg-gray-800 transition-all duration-200">
            <div class="flex justify-between items-center border-b pb-3 mb-4 dark:border-gray-700">
                <h3 class="text-lg font-semibold text-gray-900 dark:text-white">
                    <%= t('settings') %>
                </h3>
                <button id="closeModal" class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 transition">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M6 18L18 6M6 6l12 12" />
                    </svg>
                </button>
            </div>
            <!-- Appearance -->
            <div class="mb-6">
                <h4 class="font-medium text-gray-700 dark:text-gray-300 mb-2">
                    <%= t('appearance') %>
                </h4>
                <div class="flex space-x-3">
                    <button data-theme="light"
                        class="theme-btn px-3 py-1 rounded border bg-gray-200 dark:bg-gray-700 hover:bg-gray-300 dark:hover:bg-gray-600 transition">
                        <%= t('light') %>
                    </button>
                    <button data-theme="dark"
                        class="theme-btn px-3 py-1 rounded border bg-gray-200 dark:bg-gray-700 hover:bg-gray-300 dark:hover:bg-gray-600 transition">
                        <%= t('dark') %>
                    </button>
                    <button data-theme="system"
                        class="theme-btn px-3 py-1 rounded border bg-gray-200 dark:bg-gray-700 hover:bg-gray-300 dark:hover:bg-gray-600 transition">
                        <%= t('system') %>
                    </button>
                </div>
            </div>
            <!-- Language -->
            <div class="hidden">
                <h4 class="font-medium text-gray-700 dark:text-gray-300 mb-2">
                    <%= t('language') %>
                </h4>
                <select id="modalLangSwitcher"
                    class="w-full p-2 border rounded-md bg-white dark:bg-gray-700 text-gray-900 dark:text-white border-gray-300 dark:border-gray-600 focus:ring-2 focus:ring-indigo-500 focus:outline-none">
                    <option value="en" <%=locale==='en' ? 'selected' : '' %>><%= t('english') %>
                    </option>
                    <option value="ar" <%=locale==='ar' ? 'selected' : '' %>>العربية</option>
                    <option value="so" <%=locale==='so' ? 'selected' : '' %>>Soomaali</option>
                </select>
            </div>
            <% if (user && user.role==='admin' ) { %>
                <div class="mb-6 border-t pt-4 mt-4">
                    <h4 class="font-semibold mb-2">
                        <%= t('email_notifications') %>
                    </h4>
                    <label class="flex items-center justify-between">
                        <span>
                            <%= t('enable_email_reminders') %>
                        </span>
                        <input type="checkbox" id="emailNotificationsToggle" class="toggle-switch">
                    </label>
                </div>
                <% } %>
        </div>
    </div>

    <script nonce="<%= nonce %>">
        // ========== THEME MANAGEMENT ==========
        function setTheme(theme) {
            if (theme === 'dark') {
                document.documentElement.classList.add('dark');
            } else if (theme === 'light') {
                document.documentElement.classList.remove('dark');
            } else {
                if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
                    document.documentElement.classList.add('dark');
                } else {
                    document.documentElement.classList.remove('dark');
                }
            }
        }
        const savedTheme = localStorage.getItem('theme') || 'system';
        setTheme(savedTheme);
        if (savedTheme === 'system') {
            window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', () => {
                if (localStorage.getItem('theme') === 'system') setTheme('system');
            });
        }
        window.updateTheme = (value) => {
            localStorage.setItem('theme', value);
            setTheme(value);
        };

        function highlightActiveTheme() {
            const savedTheme = localStorage.getItem('theme') || 'system';
            const themeBtns = document.querySelectorAll('.theme-btn');
            themeBtns.forEach(btn => {
                if (btn.dataset.theme === savedTheme) {
                    btn.classList.add('bg-indigo-600', 'text-white');
                    btn.classList.remove('bg-gray-200', 'dark:bg-gray-700');
                } else {
                    btn.classList.remove('bg-indigo-600', 'text-white');
                    btn.classList.add('bg-gray-200', 'dark:bg-gray-700');
                }
            });
        }

        // ========== SIDEBAR TOGGLE (MOBILE) ==========
        document.addEventListener('DOMContentLoaded', () => {
            highlightActiveTheme();
            const toggleBtn = document.getElementById('menuToggle');
            const sidebar = document.getElementById('sidebar');
            const backdrop = document.getElementById('sidebarBackdrop');
            const closeBtn = document.getElementById('sidebarClose');
            if (toggleBtn && sidebar && backdrop) {
                const openSidebar = () => { sidebar.classList.add('open'); backdrop.classList.add('active'); };
                const closeSidebar = () => { sidebar.classList.remove('open'); backdrop.classList.remove('active'); };
                toggleBtn.addEventListener('click', () => {
                    if (sidebar.classList.contains('open')) closeSidebar();
                    else openSidebar();
                });
                if (backdrop) backdrop.addEventListener('click', closeSidebar);
                if (closeBtn) closeBtn.addEventListener('click', closeSidebar);
                document.querySelectorAll('#sidebar a').forEach(link => {
                    link.addEventListener('click', () => { if (window.innerWidth < 768) closeSidebar(); });
                });
            }
        });

        document.addEventListener('DOMContentLoaded', () => {
            const $ = (id) => document.getElementById(id);

            const settingsBtn = $('settingsButton');
            const settingsModal = $('settingsModal');
            const closeModalBtn = $('closeModal');

            const langDropdownBtn = $('langDropdownBtn');
            const langDropdownMenu = $('langDropdownMenu');

            const themeButtons = document.querySelectorAll('.theme-btn');
            const languageSwitchers = [
                $('modalLangSwitcher'),
                $('headerLangSwitcher')
            ].filter(Boolean);

            const getReturnUrl = () =>
                `${window.location.pathname}${window.location.search}`;

            const redirectToLanguage = (lang) => {
                window.location.href =
                    `/set-lang?lang=${encodeURIComponent(lang)}&return=${encodeURIComponent(getReturnUrl())}`;
            };

            const toggleHidden = (element, hidden) => {
                element?.classList.toggle('hidden', hidden);
            };

            // Modal
            if (settingsBtn && settingsModal) {
                settingsBtn.addEventListener('click', (e) => {
                    e.preventDefault();
                    toggleHidden(settingsModal, false);
                });

                closeModalBtn?.addEventListener('click', () => {
                    toggleHidden(settingsModal, true);
                });

                window.addEventListener('click', (e) => {
                    if (e.target === settingsModal) {
                        toggleHidden(settingsModal, true);
                    }
                });
            }

            // Language Switchers
            languageSwitchers.forEach((switcher) => {
                switcher.addEventListener('change', ({ target }) => {
                    redirectToLanguage(target.value);
                });
            });

            // Language Dropdown
            if (langDropdownBtn && langDropdownMenu) {
                langDropdownBtn.addEventListener('click', (e) => {
                    e.stopPropagation();
                    langDropdownMenu.classList.toggle('hidden');
                });

                document.addEventListener('click', ({ target }) => {
                    const clickedOutside =
                        !langDropdownBtn.contains(target) &&
                        !langDropdownMenu.contains(target);

                    if (clickedOutside) {
                        toggleHidden(langDropdownMenu, true);
                    }
                });

                document
                    .querySelectorAll('#langDropdownMenu a')
                    .forEach((link) => {
                        link.addEventListener('click', (e) => {
                            e.preventDefault();
                            redirectToLanguage(link.dataset.lang);
                        });
                    });
            }

            // Load email notification setting if admin
            if (document.getElementById('emailNotificationsToggle')) {
                const toggle = document.getElementById('emailNotificationsToggle');
                // Fetch current setting
                fetch('/api/settings/email')
                    .then(res => res.json())
                    .then(data => {
                        toggle.checked = data.enabled;
                    })
                    .catch(err => console.error('Failed to load email setting:', err));

                // On change, update server
                toggle.addEventListener('change', (e) => {
                    const enabled = e.target.checked;
                    fetch('/api/settings/email', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ enabled })
                    }).then(res => res.json()).then(data => {
                        if (data.success) console.log('Email setting updated');
                    }).catch(err => console.error('Failed to update email setting:', err));
                });
            }

            // Theme Switching
            themeButtons.forEach((button) => {
                button.addEventListener('click', () => {
                    const selectedTheme = button.dataset.theme;

                    updateTheme(selectedTheme);

                    themeButtons.forEach((btn) => {
                        const isActive = btn.dataset.theme === selectedTheme;

                        btn.classList.toggle('bg-indigo-600', isActive);
                        btn.classList.toggle('text-white', isActive);

                        btn.classList.toggle('bg-gray-200', !isActive);
                        btn.classList.toggle('dark:bg-gray-700', !isActive);
                    });
                });
            });
        });
        // ========== LOADING SPINNER ==========
        document.querySelectorAll('form:not(.no-loader)').forEach(form => {
            form.addEventListener('submit', function (e) {
                document.getElementById('loadingOverlay').classList.remove('hidden');
            });
        });
        window.addEventListener('load', () => {
            document.getElementById('loadingOverlay').classList.add('hidden');
        });
    </script>
</body>

</html>