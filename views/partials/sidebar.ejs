<!-- Navigation -->
<% if (user) { %>
    <!-- Dashboard -->
    <a href="/dashboard"
        class="flex items-center py-2 px-4 hover:bg-indigo-700 <%= currentPath === '/dashboard' ? 'bg-indigo-700' : '' %>">
        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
        </svg>
        <%= t('dashboard') %>
    </a>

    <!-- Patients -->
    <a href="/patients"
        class="flex items-center py-2 px-4 hover:bg-indigo-700 <%= currentPath === '/patients' || currentPath.startsWith('/patients/') ? 'bg-indigo-700' : '' %>">
        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
        </svg>
        <%= t('patients') %>
    </a>

    <!-- Add Patient - only for doctor and receptionist -->
    <% if (user.role==='doctor' || user.role==='receptionist' ) { %>
        <a href="/patients/new"
            class="flex items-center py-2 px-4 hover:bg-indigo-700 <%= currentPath === '/patients/new' ? 'bg-indigo-700' : '' %>">
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
            </svg>
            <%= t('add_patient') %>
        </a>
        <% } %>

            <!-- Manage Users - only for admin -->
            <% if (user.role==='admin' ) { %>
                <a href="/users"
                    class="flex items-center py-2 px-4 hover:bg-indigo-700 <%= currentPath === '/users' || currentPath.startsWith('/users/') ? 'bg-indigo-700' : '' %>">
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
                    </svg>
                    <%= t('manage_users') %>
                </a>
                <% } %>

                    <!-- Reports - visible to all logged in users -->
                    <a href="/reports"
                        class="flex items-center py-2 px-4 hover:bg-indigo-700 <%= currentPath === '/reports' || currentPath.startsWith('/reports/') ? 'bg-indigo-700' : '' %>">
                        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M9 17V7m0 10a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2h2a2 2 0 012 2m0 10a2 2 0 002 2h2a2 2 0 002-2M9 7a2 2 0 012-2h2a2 2 0 012 2m0 10V7m0 10a2 2 0 002 2h2a2 2 0 002-2V7a2 2 0 00-2-2h-2a2 2 0 00-2 2" />
                        </svg>
                        <%= t('reports') %>
                    </a>

                    <!-- Profile -->
                    <a href="/profile"
                        class="flex items-center py-2 px-4 hover:bg-indigo-700 <%= currentPath === '/profile' ? 'bg-indigo-700' : '' %>">
                        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                        </svg>
                        <%= t('profile') %>
                    </a>

                    <!-- Logout -->
                    <a href="/logout" class="flex items-center py-2 px-4 hover:bg-indigo-700">
                        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
                        </svg>
                        <%= t('logout') %>
                    </a>

                    <!-- Settings Button -->
                    <div class="p-4 border-t border-indigo-700">
                        <button id="settingsButton" class="flex items-center w-full hover:bg-indigo-700 p-2 rounded">
                            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                                <circle cx="12" cy="12" r="3" />
                            </svg>
                            <%= t('settings') %>
                        </button>
                    </div>

                    <% } else { %>
                        <!-- When not logged in - show minimal sidebar -->
                        <div class="p-4">
                            <p class="text-sm text-gray-300">Please <a href="/login"
                                    class="text-white underline">login</a></p>
                        </div>
                        <% } %>