<header class="bg-white shadow-sm">
    <div class="flex justify-between items-center px-4 md:px-6 py-4">
        <div class="flex items-center space-x-3">
            <button id="menuToggle" class="menu-toggle text-gray-600 hover:text-gray-900 focus:outline-none md:hidden">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
                </svg>
            </button>
            <h1 class="text-xl font-semibold text-gray-800">
                <%= t('welcome') %>, <%= user ? user.username : 'Guest' %>
            </h1>
        </div>
        <div class="flex items-center space-x-4">
            <!-- Language switcher -->
            <!-- <select id="headerLangSwitcher" class="text-sm border rounded px-2 py-1">
                <option value="en" <%= locale === 'en' ? 'selected' : '' %>>English</option>
                <option value="ar" <%= locale === 'ar' ? 'selected' : '' %>>العربية</option>
                <option value="so" <%= locale === 'so' ? 'selected' : '' %>>Soomaali</option>
            </select> -->
            <!-- Language Dropdown -->
            <div class="relative">
                <button id="langDropdownBtn"
                    class="flex items-center space-x-1 text-gray-700 dark:text-gray-200 hover:text-gray-900 dark:hover:text-white focus:outline-none">
                    <span class="text-sm font-medium">
                        <%= locale==='en' ? 'English' : (locale==='ar' ? 'العربية' : 'Soomaali' ) %>
                    </span>
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                    </svg>
                </button>
                <div id="langDropdownMenu"
                    class="absolute right-0 mt-2 w-32 bg-white dark:bg-gray-800 rounded-md shadow-lg py-1 z-20 hidden">
                    <a href="#" data-lang="en"
                        class="block px-4 py-2 text-sm text-gray-700 dark:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-700 <%= locale === 'en' ? 'bg-gray-100 dark:bg-gray-700' : '' %>">English</a>
                    <a href="#" data-lang="ar"
                        class="block px-4 py-2 text-sm text-gray-700 dark:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-700 <%= locale === 'ar' ? 'bg-gray-100 dark:bg-gray-700' : '' %>">العربية</a>
                    <a href="#" data-lang="so"
                        class="block px-4 py-2 text-sm text-gray-700 dark:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-700 <%= locale === 'so' ? 'bg-gray-100 dark:bg-gray-700' : '' %>">Soomaali</a>
                </div>
            </div>
            <% if (user) { %>
                <span class="px-3 py-1 text-sm rounded-full 
                    <%= user.role === 'admin' ? 'bg-purple-100 text-purple-800' : 
                        (user.role === 'doctor' ? 'bg-indigo-100 text-indigo-800' : 'bg-gray-100 text-gray-800') %>">
                    <%= user.role==='admin' ? 'Administrator' : (user.role==='doctor' ? 'Doctor/Nurse'
                        : 'Receptionist' ) %>
                </span>
                <div
                    class="w-8 h-8 rounded-full bg-indigo-200 flex items-center justify-center text-indigo-800 font-bold">
                    <a href="/profile">
                        <%= user.username.charAt(0).toUpperCase() %>
                    </a>
                </div>
                <% } %>
        </div>
    </div>
</header>