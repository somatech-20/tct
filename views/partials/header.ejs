<header class="bg-white shadow-sm">
    <div class="flex justify-between items-center px-4 md:px-6 py-4">
        <div class="flex items-center space-x-3">
            <button id="menuToggle" class="menu-toggle text-gray-600 hover:text-gray-900 focus:outline-none md:hidden">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
                </svg>
            </button>
            <h1 class="text-xl font-semibold text-gray-800">Welcome, <%= user ? user.username : 'Guest' %></h1>
        </div>
        <div class="flex items-center space-x-3">
            <% if (user) { %>
            <span class="px-3 py-1 text-sm rounded-full ..."><%= user.role === 'admin' ? 'Administrator' : (user.role === 'doctor' ? 'Doctor/Nurse' : 'Contact Tracer') %></span>
            <div class="w-8 h-8 rounded-full bg-indigo-200 flex items-center justify-center text-indigo-800 font-bold">
                <a href="/profile" class="flex items-center py-2 px-4 hover:bg-indigo-200 <%= currentPath === '/profile'%>">
                    <%= user.username.charAt(0).toUpperCase() %>
                </a>
            </div>
            <% } %>
        </div>
    </div>
</header>