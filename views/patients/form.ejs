<div class="bg-white shadow rounded-lg p-6 max-w-2xl mx-auto">
    <h2 class="text-xl font-bold mb-6">
        <%= patient ? 'Edit Patient' : 'Add Patient' %>
    </h2>
    <form method="POST" action="/patients<%= patient ? '/'+patient._id+'?_method=PUT' : '' %>">
        <div class="mb-4">
            <label>Email</label>
            <input type="email" name="email" value="<%= patient ? patient.email : '' %>">
        </div>
        <div class="mb-4">
            <label>Phone</label>
            <input type="tel" name="phone" value="<%= patient ? patient.phone : '' %>">
        </div>
        <div class="mb-4">
            <label class="block text-gray-700 text-sm font-bold mb-2">Full Name</label>
            <input type="text" name="fullName" value="<%= patient ? patient.fullName : '' %>"
                pattern="[A-Za-z ]+" title="Full Name should only contain letters and spaces"
                class="shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline"
                required>
        </div>
        <div class="grid grid-cols-2 gap-4 mb-4">
            <div>
                <label class="block text-gray-700 text-sm font-bold mb-2">Age</label>
                <input type="number" name="age" value="<%= patient ? patient.age : '' %>"
                    class="shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline"
                    required>
            </div>
            <div>
                <label class="block text-gray-700 text-sm font-bold mb-2">Gender</label>
                <select name="gender"
                    class="shadow border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline"
                    required>
                    <option value="Male" <%=patient && patient.gender==='Male' ? 'selected' : '' %>>Male</option>
                    <option value="Female" <%=patient && patient.gender==='Female' ? 'selected' : '' %>>Female</option>
                    <option value="Other" <%=patient && patient.gender==='Other' ? 'selected' : '' %>>Other</option>
                </select>
            </div>
        </div>
        <div class="mb-4">
            <label class="block text-gray-700 text-sm font-bold mb-2">Address</label>
            <textarea name="address"
                class="shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline"
                required><%= patient ? patient.address : '' %></textarea>
        </div>
        <div class="grid grid-cols-2 gap-4 mb-4">
            <div>
                <label class="block text-gray-700 text-sm font-bold mb-2">TB Type</label>
                <select name="tbType"
                    class="shadow border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline"
                    required>
                    <option value="Pulmonary" <%=patient && patient.tbType==='Pulmonary' ? 'selected' : '' %>>Pulmonary
                    </option>
                    <option value="Extra-pulmonary" <%=patient && patient.tbType==='Extra-pulmonary' ? 'selected' : ''
                        %>>Extra-pulmonary</option>
                </select>
            </div>
            <div>
                <label class="block text-gray-700 text-sm font-bold mb-2">Treatment Start Date</label>
                <input type="date" name="treatmentStartDate"
                    value="<%= patient ? patient.treatmentStartDate.toISOString().split('T')[0] : '' %>"
                    class="shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline"
                    required>
            </div>
        </div>
        <div class="mb-6">
            <label class="block text-gray-700 text-sm font-bold mb-2">Status</label>
            <select name="status"
                class="shadow border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline"
                required>
                <option value="Active" <%=patient && patient.status==='Active' ? 'selected' : '' %>>Active</option>
                <option value="Recovered" <%=patient && patient.status==='Recovered' ? 'selected' : '' %>>Recovered
                </option>
                <option value="Defaulted" <%=patient && patient.status==='Defaulted' ? 'selected' : '' %>>Defaulted
                </option>
            </select>
        </div>
        <div class="flex items-center justify-between">
            <button type="submit"
                class="bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-2 px-4 rounded focus:outline-none focus:shadow-outline">Save</button>
            <a href="/patients"
                class="inline-block align-baseline font-bold text-sm text-indigo-600 hover:text-indigo-800">Cancel</a>
        </div>
    </form>
</div>