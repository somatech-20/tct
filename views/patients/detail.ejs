<div class="bg-white shadow rounded-lg p-6 mb-6">
    <h2 class="text-xl font-bold mb-4"><%= patient.fullName %></h2>
    <div class="grid grid-cols-2 gap-4">
        <div><span class="font-semibold"><%= t('age') %>:</span> <%= patient.age %></div>
        <div><span class="font-semibold"><%= t('gender') %>:</span> <%= patient.gender %></div>
        <div><span class="font-semibold"><%= t('address') %>:</span> <%= patient.address %></div>
        <div><span class="font-semibold"><%= t('tb_type') %>:</span> <%= patient.tbType %></div>
        <div><span class="font-semibold"><%= t('treatment_start') %>:</span> <%= patient.treatmentStartDate.toDateString() %></div>
        <div><span class="font-semibold"><%= t('status') %>:</span> <span class="badge"><%= patient.status %></span></div>
    </div>
</div>

<div class="bg-white shadow rounded-lg p-6 mb-6">
    <div class="flex justify-between items-center mb-4">
        <h3 class="text-lg font-semibold"><%= t('treatment_logs') %></h3>
        <% if (user.role === 'doctor') { %>
        <a href="/patients/<%= patient._id %>/treatments/new" class="bg-indigo-600 text-white px-3 py-1 rounded text-sm"><%= t('add_log') %></a>
        <% } %>
    </div>
    <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
            <thead>
                <tr><th class="px-4 py-3 text-left">Date</th><th class="px-4 py-3 text-left">Dose Taken</th><th class="px-4 py-3 text-left">Sputum Result</th><th class="px-4 py-3 text-left">Notes</th></tr>
            </thead>
            <tbody>
                <% treatments.forEach(log => { %>
                <tr>
                    <td class="px-4 py-3"><%= log.date.toDateString() %></td>
                    <td class="px-4 py-3"><%= log.doseTaken ? 'Yes' : 'No' %></td>
                    <td class="px-4 py-3"><%= log.sputumResult %></td>
                    <td class="px-4 py-3"><%= log.notes || '' %></td>
                </tr>
                <% }); %>
            </tbody>
        </table>
    </div>
</div>

<div class="bg-white shadow rounded-lg p-6">
    <div class="flex justify-between items-center mb-4">
        <h3 class="text-lg font-semibold">Contacts</h3>
        <a href="/patients/<%= patient._id %>/contacts/new" class="bg-indigo-600 text-white px-3 py-1 rounded text-sm">Add Contact</a>
    </div>
    <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
            <thead>
                <tr><th class="px-4 py-3 text-left">Name</th><th class="px-4 py-3 text-left">Relationship</th><th class="px-4 py-3 text-left">Screening Date</th><th class="px-4 py-3 text-left">Symptoms</th><th class="px-4 py-3 text-left">Status</th></tr>
            </thead>
            <tbody>
                <% contacts.forEach(contact => { %>
                <tr>
                    <td class="px-4 py-3"><%= contact.fullName %></td>
                    <td class="px-4 py-3"><%= contact.relationship %></td>
                    <td class="px-4 py-3"><%= contact.screeningDate.toDateString() %></td>
                    <td class="px-4 py-3"><%= contact.symptoms || '' %></td>
                    <td class="px-4 py-3"><%= contact.screeningStatus %></td>
                </tr>
                <% }); %>
            </tbody>
        </table>
    </div>
</div>
